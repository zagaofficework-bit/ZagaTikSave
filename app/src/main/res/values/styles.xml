<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/background_main</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
    </style>
    <style name="ActivityCommon" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/background_main</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_return</item>
    </style>
    <style name="itemBigContentStyle">
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
    </style>
    <style name="Universal.Widget.ProgressBar" parent="@android:style/Widget.ProgressBar">
        <item name="android:indeterminateDrawable">@drawable/uvv_progress_rotate</item>
        <item name="android:indeterminateDuration">1000</item>
    </style>


    <style name="bottomToTopAnim" parent="android:Animation">
        <item name="@android:windowEnterAnimation">@anim/bottomview_anim_enter</item>
        <item name="@android:windowExitAnimation">@anim/bottomview_anim_exit</item>
    </style>

    <style name="dialog" parent="AppTheme">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:backgroundDimEnabled" tools:targetApi="cupcake">true</item>
    </style>

    <style name="FontMedium">
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/product_regular</item>
    </style>
    <style name="itemContentStyle">
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
    </style>
    <style name="PopupThemeDark">
        <item name="colorSurface">#ed111111</item>
        <item name="elevationOverlayColor">@color/black</item>
    </style>
    <style name="AppThemeTranslucentStatusBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    <style name="TextButtonDialog">
        <item name="fontFamily">@font/erasbd</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_color_main</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">24dp</item>
    </style>
    <style name="CustomExoMediaButton">
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
        <item name="android:scaleType">center</item>
    </style>
    <style name="CustomExoMediaButton.Play">
        <item name="android:layout_width">160dp</item>
        <item name="android:layout_height">160dp</item>
        <item name="srcCompat">@drawable/ic_play_player</item>
    </style>
    <style name="tab_text" parent="@android:style/TextAppearance.Widget.TabWidget">
        <item name="android:fontFamily">@font/erasbd</item>
        <item name="android:textColor">@color/tab_indicator_text</item>
    </style>
    <style name="AppBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppModalStyle</item>
    </style>
    <style name="AppModalStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background"></item>
    </style>
    <style name="TextTitle15">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_color_main</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">clip_horizontal</item>
        <item name="maxLines">1</item>
    </style>
    <style name="Text13">
        <item name="fontFamily">@font/product_regular</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_color_second</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">clip_horizontal</item>
        <item name="maxLines">1</item>
    </style>
    <style name="FontSemiBold">
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/product_bold</item>
    </style>
    <style name="TextToolbar">
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/product_bold</item>
        <item name="android:textSize">17sp</item>
    </style>
</resources>